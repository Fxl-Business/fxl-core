#!/bin/bash
set -e

echo "============================================"
echo "  FXL Doctor — Conformance Check"
echo "============================================"
echo ""

ERRORS=0

# 1. TypeScript type-check
echo "[1/5] TypeScript type-check..."
if bunx tsc --noEmit; then
  echo "  PASS: TypeScript"
else
  echo "  FAIL: TypeScript errors found"
  ERRORS=$((ERRORS + 1))
fi
echo ""

# 2. ESLint
echo "[2/5] ESLint..."
if bunx eslint .; then
  echo "  PASS: ESLint"
else
  echo "  FAIL: ESLint errors found"
  ERRORS=$((ERRORS + 1))
fi
echo ""

# 3. Prettier
echo "[3/5] Prettier formatting..."
if bunx prettier --check .; then
  echo "  PASS: Prettier"
else
  echo "  FAIL: Formatting issues found (run: bunx prettier --write .)"
  ERRORS=$((ERRORS + 1))
fi
echo ""

# 4. Security headers check
echo "[4/5] Security headers..."
if [ -f "vercel.json" ]; then
  node --input-type=module -e "
    import { readFileSync } from 'fs';
    const v = JSON.parse(readFileSync('./vercel.json', 'utf8'));
    const allHeaders = (v.headers || []).flatMap(h => (h.headers || []).map(hh => hh.key));
    const required = ['X-Frame-Options', 'X-Content-Type-Options'];
    const missing = required.filter(r => !allHeaders.includes(r));
    if (missing.length) {
      console.error('  FAIL: Missing security headers:', missing.join(', '));
      process.exit(1);
    }
    console.log('  PASS: Security headers');
  "
  if [ $? -ne 0 ]; then
    ERRORS=$((ERRORS + 1))
  fi
else
  echo "  FAIL: vercel.json not found"
  ERRORS=$((ERRORS + 1))
fi
echo ""

# 5. Contract version check
echo "[5/5] Contract version..."
if [ -f "package.json" ]; then
  node --input-type=module -e "
    import { readFileSync } from 'fs';
    const pkg = JSON.parse(readFileSync('./package.json', 'utf8'));
    const v = pkg.fxlContractVersion;
    if (!v) {
      console.error('  FAIL: Missing fxlContractVersion in package.json');
      process.exit(1);
    }
    const MIN = '1.0';
    if (v < MIN) {
      console.error('  FAIL: Contract version', v, '< required', MIN);
      process.exit(1);
    }
    console.log('  PASS: Contract version', v);
  "
  if [ $? -ne 0 ]; then
    ERRORS=$((ERRORS + 1))
  fi
else
  echo "  FAIL: package.json not found"
  ERRORS=$((ERRORS + 1))
fi
echo ""

# Summary
echo "============================================"
if [ $ERRORS -eq 0 ]; then
  echo "  FXL Doctor — ALL CHECKS PASSED"
  echo "============================================"
  exit 0
else
  echo "  FXL Doctor — $ERRORS CHECK(S) FAILED"
  echo "============================================"
  exit 1
fi
