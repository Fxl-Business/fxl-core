### Task 2: Implement queryAuditLogs() function

<read_first>
- src/modules/admin/services/audit-service.ts (current state — may have logAuditEvent from Phase 135)
- src/modules/admin/types/audit.ts (types just created in Task 1)
- src/lib/supabase.ts (Supabase client import pattern)
</read_first>

<action>
Add `queryAuditLogs()` to `src/modules/admin/services/audit-service.ts`. If the file doesn't exist yet, create it with only this function (Phase 135 will add logAuditEvent later or already added it).

```ts
import { supabase } from '@/lib/supabase'
import type { AuditLogQueryParams, AuditLogQueryResult, AuditLog } from '../types/audit'

const MAX_LIMIT = 100

export async function queryAuditLogs(params: AuditLogQueryParams): Promise<AuditLogQueryResult> {
  const limit = Math.min(params.limit ?? 50, MAX_LIMIT)
  const offset = params.offset ?? 0

  let query = supabase
    .from('audit_logs')
    .select('*', { count: 'exact' })

  // Apply filters
  if (params.org_id) {
    query = query.eq('org_id', params.org_id)
  }
  if (params.actor_id) {
    query = query.eq('actor_id', params.actor_id)
  }
  if (params.action) {
    query = query.eq('action', params.action)
  }
  if (params.resource_type) {
    query = query.eq('resource_type', params.resource_type)
  }

  // Apply pagination and ordering
  query = query
    .order('created_at', { ascending: false })
    .range(offset, offset + limit - 1)

  const { data, count, error } = await query

  if (error) {
    throw new Error(`Failed to query audit logs: ${error.message}`)
  }

  return {
    data: (data ?? []) as AuditLog[],
    total: count ?? 0,
    limit,
    offset,
  }
}
```

Key implementation details:
- MAX_LIMIT = 100 enforced server-side via Math.min
- Default limit = 50, default offset = 0
- Uses `select('*', { count: 'exact' })` to get total count for pagination
- Orders by created_at DESC (newest first)
- Uses `.range()` for offset pagination
- Throws on error (edge function will catch and return 500)
- No `any` — uses typed AuditLog[] cast on Supabase response
</action>

