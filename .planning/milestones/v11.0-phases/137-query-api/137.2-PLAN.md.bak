- supabase/functions/admin-tenants/index.ts (reference pattern for: Supabase client creation with service role key, query param parsing)
- src/modules/admin/types/audit.ts (AuditLog type shape — must match but will be redefined inline for Deno)
</read_first>

<action>
Create `supabase/functions/audit-logs/index.ts` following the exact patterns from admin-users and admin-tenants:

```ts
// Supabase Edge Function: audit-logs
// Queries audit_logs table with filters and pagination for super admin use.
//
// Runtime: Deno (Supabase Functions)
// Methods: GET (query with filters)
// Auth: Bearer token with super_admin JWT claim required
// Returns: { data: AuditLog[], total: number, limit: number, offset: number }

// @ts-nocheck — Deno runtime, not checked by project tsc
import { serve } from 'https://deno.land/std@0.177.0/http/server.ts'
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2.39.3'

const SUPABASE_URL = Deno.env.get('SUPABASE_URL')
const SUPABASE_SERVICE_ROLE_KEY = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')

const MAX_LIMIT = 100

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
  'Access-Control-Allow-Methods': 'GET, OPTIONS',
}

serve(async (req: Request) => {
  // Handle CORS preflight
  if (req.method === 'OPTIONS') {
    return new Response(null, { status: 204, headers: corsHeaders })
  }

  // Only GET is supported
  if (req.method !== 'GET') {
    return jsonError('Method not allowed', 405)
  }

  // Validate Supabase config
  if (!SUPABASE_URL || !SUPABASE_SERVICE_ROLE_KEY) {
    return jsonError('Server configuration error', 500)
  }

  // Extract JWT from Authorization header
  const authHeader = req.headers.get('Authorization')
  if (!authHeader?.startsWith('Bearer ')) {
    return jsonError('Missing or invalid Authorization header', 401)
  }
  const token = authHeader.slice(7)

  // Decode JWT payload (Supabase gateway already verified the token)
  let payload: Record<string, unknown>
  try {
    const parts = token.split('.')
    if (parts.length !== 3) {
      return jsonError('Invalid JWT format', 401)
    }
    const base64 = parts[1].replace(/-/g, '+').replace(/_/g, '/')
    const padded = base64.padEnd(base64.length + (4 - base64.length % 4) % 4, '=')
    payload = JSON.parse(atob(padded)) as Record<string, unknown>
  } catch {
    return jsonError('Failed to decode token', 401)
  }

  // Enforce super_admin claim (handles both boolean true and string "true")
  if (payload.super_admin !== true && payload.super_admin !== 'true') {
    return jsonError('Forbidden: super_admin required', 403)
  }

  // Parse query parameters for filters and pagination
  const url = new URL(req.url)
  const orgId = url.searchParams.get('org_id')
  const actorId = url.searchParams.get('actor_id')
  const action = url.searchParams.get('action')
  const resourceType = url.searchParams.get('resource_type')
  const limitParam = parseInt(url.searchParams.get('limit') ?? '50', 10)
  const offsetParam = parseInt(url.searchParams.get('offset') ?? '0', 10)

  const limit = Math.min(isNaN(limitParam) ? 50 : limitParam, MAX_LIMIT)
  const offset = isNaN(offsetParam) ? 0 : offsetParam

  // Query audit_logs with service role (bypasses RLS)
  const supabase = createClient(SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY)

  let query = supabase
    .from('audit_logs')
    .select('*', { count: 'exact' })

  // Apply filters (only when provided)
  if (orgId) {
    query = query.eq('org_id', orgId)
  }
  if (actorId) {
    query = query.eq('actor_id', actorId)
  }
  if (action) {
    query = query.eq('action', action)
  }
  if (resourceType) {
    query = query.eq('resource_type', resourceType)
  }

  // Apply pagination and ordering
  query = query
    .order('created_at', { ascending: false })
    .range(offset, offset + limit - 1)

  const { data, count, error } = await query

  if (error) {
    return jsonError(`Query failed: ${error.message}`, 500)
  }

  return jsonOk({
    data: data ?? [],
    total: count ?? 0,
    limit,
    offset,
  })
})

function jsonOk(data: unknown): Response {
  return new Response(JSON.stringify(data), {
    status: 200,
    headers: { ...corsHeaders, 'Content-Type': 'application/json' },
  })
}

function jsonError(error: string, status: number): Response {
  return new Response(JSON.stringify({ error }), {
    status,
    headers: { ...corsHeaders, 'Content-Type': 'application/json' },
  })
}
```

Key design decisions matching PITFALLS.md and existing patterns:
- CORS headers identical to admin-users/admin-tenants
- JWT decoding pattern identical to admin-users (base64url decode, no crypto verification — gateway handles that)
- super_admin check handles both `true` and `"true"` (same as admin-users line 55)
- Uses `createClient` with `SUPABASE_SERVICE_ROLE_KEY` (same pattern as admin-tenants line 27) — bypasses RLS to query all audit logs
- Query params for filters (not sub-paths — PITFALLS.md rule #5)
- `data ?? []` fallback (PITFALLS.md rule #6)
- `count ?? 0` fallback
- MAX_LIMIT = 100 enforced server-side
- Only GET method allowed (405 for others)
- `// @ts-nocheck` at top (Deno runtime, not checked by project tsc — same as all other edge functions)
</action>

<acceptance_criteria>
- File exists at `supabase/functions/audit-logs/index.ts`
- File starts with `// @ts-nocheck` comment
- Contains `corsHeaders` with same structure as admin-users
- Contains JWT decoding with base64url decode (same pattern as admin-users)
- Contains `payload.super_admin !== true && payload.super_admin !== 'true'` check
- Returns 401 when no Authorization header
- Returns 403 when super_admin claim is missing/false
- Returns 405 for non-GET methods
- Parses query params: `org_id`, `actor_id`, `action`, `resource_type`, `limit`, `offset`
- `MAX_LIMIT` constant equals 100
- `Math.min(...)` enforces server-side limit cap
- Uses `createClient(SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY)` for service role access
- Query uses `.select('*', { count: 'exact' })` for total count
- Query applies `.eq()` filters conditionally (only when param is truthy)
- Query applies `.order('created_at', { ascending: false })`
- Response shape: `{ data: [], total: number, limit: number, offset: number }`
- `data ?? []` fallback present
- `count ?? 0` fallback present
</acceptance_criteria>

