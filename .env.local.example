VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# --- Smoke test (make smoke-test) ---
# JWT_SIGNING_SECRET: same secret used by auth-token-exchange edge function
# Find it in Supabase Dashboard -> Settings -> API -> JWT Secret
JWT_SIGNING_SECRET=your-jwt-signing-secret-here
# SMOKE_TEST_USER_ID: any valid Clerk user sub (find in Clerk Dashboard -> Users)
SMOKE_TEST_USER_ID=user_your_clerk_user_id
# SMOKE_TEST_ORG_A: org ID with documents (org to test positive case)
SMOKE_TEST_ORG_A=org_your_org_with_data
# SMOKE_TEST_ORG_B: org ID with zero documents (org to test isolation)
SMOKE_TEST_ORG_B=org_your_empty_org
